#!/usr/bin/env stash

/*
 * Lifecycle Hooks & Skip Demo
 * ---------------------------
 * Run with: stash --test lifecycle_hooks.test.stash
 *
 * Demonstrates:
 *   - test.skip() for marking tests as pending
 *   - test.beforeAll() / test.afterAll() for one-time setup and teardown
 *   - test.beforeEach() / test.afterEach() for per-test setup and teardown
 *   - Nested test.describe() blocks inheriting parent hooks
 *   - All hooks combined with test.skip() in the middle
 */

// Shared state uses single-element arrays because closures capture
// the array reference (mutable), not a copy of the int value.

fn make_log() {
    return [];
}

fn push_event(log, name) {
    arr.push(log, name);
}

// ---

test.describe("test.skip()", () => {
    test.it("this test runs", () => {
        assert.equal(2 + 2, 4);
    });

    test.skip("not yet implemented", () => {
        // body never executes — safe to reference unfinished logic
        assert.fail("should never reach here");
    });

    test.skip("known flaky on CI", () => {
        assert.equal(1, 2); // wrong, but body is never run
    });

    test.it("this also runs", () => {
        assert.true(true);
    });
});

test.describe("beforeAll / afterAll", () => {
    let items = [];

    test.beforeAll(() => {
        arr.push(items, "initialized");
    });

    test.afterAll(() => {
        arr.push(items, "cleaned up");
    });

    test.it("beforeAll ran before the first test", () => {
        assert.equal(len(items), 1);
        assert.equal(items[0], "initialized");
    });

    test.it("items grows as tests add data", () => {
        arr.push(items, "test data");
        assert.equal(len(items), 2);
        assert.equal(items[1], "test data");
    });

    test.it("afterAll has not run yet", () => {
        // afterAll appends "cleaned up", but it hasn't fired yet
        assert.false("cleaned up" in items);
    });
});

test.describe("beforeEach / afterEach", () => {
    let counter = [0];

    test.beforeEach(() => {
        counter[0] = 1; // reset and prime to 1 before every test
    });

    test.afterEach(() => {
        // counter must be >= 1 after each test body
        assert.greater(counter[0], 0);
    });

    test.it("counter starts at 1", () => {
        assert.equal(counter[0], 1);
    });

    test.it("mutations in one test do not bleed into the next", () => {
        // beforeEach reset it back to 1; previous test's change is gone
        assert.equal(counter[0], 1);
        counter[0] = 99;
    });

    test.it("counter is 1 again after reset", () => {
        assert.equal(counter[0], 1);
        counter[0] += 4;
        assert.equal(counter[0], 5);
    });
});

test.describe("nested hooks", () => {
    let log = make_log();

    test.beforeEach(() => {
        push_event(log, "outer-before");
    });

    test.afterEach(() => {
        push_event(log, "outer-after");
    });

    test.it("outer test", () => {
        push_event(log, "outer-test");
    });

    test.describe("inner group", () => {
        test.beforeEach(() => {
            push_event(log, "inner-before");
        });

        test.afterEach(() => {
            push_event(log, "inner-after");
        });

        test.it("inner test", () => {
            push_event(log, "inner-test");
        });
    });

    test.it("verify hook execution order", () => {
        // By now, the log contains all events from the two preceding tests.
        // Outer test:  outer-before → outer-test → outer-after
        // Inner test:  outer-before → inner-before → inner-test → inner-after → outer-after
        // This test:   outer-before (already appended by this test's beforeEach)
        assert.equal(log[0], "outer-before");
        assert.equal(log[1], "outer-test");
        assert.equal(log[2], "outer-after");
        assert.equal(log[3], "outer-before");
        assert.equal(log[4], "inner-before");
        assert.equal(log[5], "inner-test");
        assert.equal(log[6], "inner-after");
        assert.equal(log[7], "outer-after");
        assert.equal(log[8], "outer-before"); // this test's beforeEach
    });
});

test.describe("combined lifecycle", () => {
    let events = make_log();

    test.beforeAll(() => { push_event(events, "SETUP"); });
    test.afterAll(() => { push_event(events, "TEARDOWN"); });
    test.beforeEach(() => { push_event(events, "before"); });
    test.afterEach(() => { push_event(events, "after"); });

    test.it("first", () => {
        push_event(events, "test-1");
    });

    test.it("second", () => {
        push_event(events, "test-2");
    });

    test.skip("third (pending)", () => {
        // skipped tests don't run hooks either
        push_event(events, "test-3");
    });

    test.it("verify full lifecycle sequence", () => {
        // SETUP
        // before → test-1 → after
        // before → test-2 → after
        // (skip: nothing)
        // before                    ← this test's beforeEach just fired
        assert.equal(events[0], "SETUP");
        assert.equal(events[1], "before");
        assert.equal(events[2], "test-1");
        assert.equal(events[3], "after");
        assert.equal(events[4], "before");
        assert.equal(events[5], "test-2");
        assert.equal(events[6], "after");
        assert.equal(events[7], "before");
        // "test-3" must not appear — skipped tests don't execute
        assert.false("test-3" in events);
    });
});
