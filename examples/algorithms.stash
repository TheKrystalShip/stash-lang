#!/usr/bin/env stash

/*
 * Algorithms & Language Feature Demo
 * -----------------------------------
 * Showcases recursion, pipes, print vs println,
 * and assorted operators.
 */

// --- Recursion ---

fn factorial(n) {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

fn fibonacci(n) {
    if (n <= 0) { return 0; }
    if (n == 1) { return 1; }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

println("=== Recursion ===");
println($"  factorial(5) = {factorial(5)}");
println($"  factorial(10) = {factorial(10)}");

print("  fibonacci(0..10) = ");
let i = 0;
while (i <= 10) {
    print($"{fibonacci(i)}");
    if (i < 10) {
        print(", ");
    }
    i++;
}
println("");
println("");

// --- Sorting (bubble sort, shows >, >=, binary subtraction) ---

fn bubble_sort(arr) {
    let n = len(arr);
    let swapped = true;

    while (swapped) {
        swapped = false;
        let j = 0;
        while (j < n - 1) {
            if (arr[j] > arr[j + 1]) {
                // Swap
                let temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
                swapped = true;
            }
            j++;
        }
        n = n - 1;
    }
    return arr;
}

println("=== Bubble Sort ===");
let nums = [64, 34, 25, 12, 22, 11, 90];

print("  Before: ");
for (let n in nums) {
    print($"{n} ");
}
println("");

bubble_sort(nums);

print("  After:  ");
for (let n in nums) {
    print($"{n} ");
}
println("");
println("");

// --- Max/Min with >= ---

fn find_max(arr) {
    let max = arr[0];
    let i = 1;
    while (i < len(arr)) {
        if (arr[i] >= max) {
            max = arr[i];
        }
        i++;
    }
    return max;
}

fn find_min(arr) {
    let min = arr[0];
    let i = 1;
    while (i < len(arr)) {
        if (arr[i] <= min) {
            min = arr[i];
        }
        i++;
    }
    return min;
}

let sorted = [11, 12, 22, 25, 34, 64, 90];
let range = find_max(sorted) - find_min(sorted);
println("=== Array Stats ===");
println($"  Min:   {find_min(sorted)}");
println($"  Max:   {find_max(sorted)}");
println($"  Range: {range}");
println("");

// --- Pipes (Stash pipe operator) ---

println("=== Pipes ===");
let result = $(echo "hello world stash language") | $(tr " " "\n") | $(sort);
println($"  Pipe result ({typeof(result)}):");
println($"  stdout: {result.stdout}");
println($"  exit code: {result.exitCode}");
