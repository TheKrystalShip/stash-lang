/// Shows properties of a specific seat.
/// Runs `loginctl show-seat <seat> --no-pager` and parses KEY=VALUE output into a dict.
/// @param seat Seat name (e.g. "seat0")
/// @return Dict with ok (bool), data (dict of properties), stderr, exitCode
fn show_seat(seat) {
    let cmd = $"loginctl show-seat {seat} --no-pager";
    let result = exec(cmd);
    if (!result.ok) {
        return result;
    }
    let props = parse_properties(result.stdout);
    return {
        ok: true,
        data: props,
        stderr: result.stderr,
        exitCode: result.exitCode
    };
}
