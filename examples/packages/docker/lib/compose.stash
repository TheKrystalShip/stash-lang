    build:          { flag: "--build", type: "bool" },
    force_recreate: { flag: "--force-recreate", type: "bool" },
    no_recreate:    { flag: "--no-recreate", type: "bool" }
};

let rm_services_spec = {
    force:   { flag: "--force", type: "bool" },
    stop:    { flag: "--stop", type: "bool" },
    volumes: { flag: "--volumes", type: "bool" }
};

let kill_spec = {
    signal: { flag: "--signal" }
};

