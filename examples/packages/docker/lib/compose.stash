    build:          { flag: "--build", type: "bool" },
    force_recreate: { flag: "--force-recreate", type: "bool" },
    no_deps:        { flag: "--no-deps", type: "bool" },
    timeout:        { flag: "--timeout" },
    wait:           { flag: "--wait", type: "bool" },
    pull:           { flag: "--pull" },
    remove_orphans: { flag: "--remove-orphans", type: "bool" }
};

let down_spec = {
    volumes:        { flag: "--volumes", type: "bool" },
    rmi:            { flag: "--rmi" },
    timeout:        { flag: "--timeout" },
    remove_orphans: { flag: "--remove-orphans", type: "bool" }
};

let build_services_spec = {
    no_cache: { flag: "--no-cache", type: "bool" },
    pull:     { flag: "--pull", type: "bool" },
    quiet:    { flag: "--quiet", type: "bool" }
};

