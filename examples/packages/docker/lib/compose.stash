    follow:     { flag: "--follow", type: "bool" },
    tail:       { flag: "--tail" },
    timestamps: { flag: "--timestamps", type: "bool" },
    no_color:   { flag: "--no-color", type: "bool" },
    since:      { flag: "--since" },
    until:      { flag: "--until" }
};

