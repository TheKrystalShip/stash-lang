    detach:  { flag: "--detach", type: "bool" },
    user:    { flag: "--user" },
    workdir: { flag: "--workdir" },
    env:     { flag: "-e", type: "map" }
};

let run_service_spec = {
    detach:  { flag: "--detach", type: "bool" },
    rm:      { flag: "--rm", type: "bool" },
    user:    { flag: "--user" },
    workdir: { flag: "--workdir" },
    env:     { flag: "-e", type: "map" },
    no_deps: { flag: "--no-deps", type: "bool" }
};

let restart_spec = {
    timeout: { flag: "--timeout" }
};

let stop_spec = {
    timeout: { flag: "--timeout" }
};

let pull_services_spec = {
    quiet:                { flag: "--quiet", type: "bool" },
    ignore_pull_failures: { flag: "--ignore-pull-failures", type: "bool" },
    include_deps:         { flag: "--include-deps", type: "bool" }
};

