#!/usr/bin/env stash

/*
 * Testing Demo
 * ------------
 * Run with: stash --test testing.test.stash
 *
 * Comprehensive test suite demonstrating the built-in testing infrastructure:
 *   - test.describe() / test.it() for structure
 *   - assert.* for assertions
 *   - test.captureOutput() for testing printed output
 */

// --- Helper functions ---

fn factorial(n) {
    if (n <= 1) { return 1; }
    return n * factorial(n - 1);
}

fn fibonacci(n) {
    if (n <= 0) { return 0; }
    if (n == 1) { return 1; }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

fn to_slug(title) {
    let slug = str.lower(str.trim(title));
    slug = str.replaceAll(slug, " ", "-");
    slug = str.replaceAll(slug, "_", "-");
    return slug;
}

// --- Tests ---

test.describe("math", () => {
    test.it("factorial base cases", () => {
        assert.equal(factorial(0), 1);
        assert.equal(factorial(1), 1);
    });

    test.it("factorial recursive", () => {
        assert.equal(factorial(5), 120);
        assert.equal(factorial(10), 3628800);
    });

    test.it("fibonacci sequence", () => {
        assert.equal(fibonacci(0), 0);
        assert.equal(fibonacci(1), 1);
        assert.equal(fibonacci(6), 8);
        assert.equal(fibonacci(10), 55);
    });

    test.it("arithmetic operators", () => {
        assert.equal(10 + 5, 15);
        assert.equal(10 - 5, 5);
        assert.equal(10 * 5, 50);
        assert.equal(10 / 3, 3);   // integer division
        assert.equal(10 % 3, 1);
    });

    test.it("math.pow and math.sqrt", () => {
        assert.equal(math.pow(2, 10), 1024.0);
        assert.equal(math.pow(3, 3), 27.0);
        assert.equal(math.sqrt(9), 3.0);
        assert.equal(math.sqrt(4.0), 2.0);
    });

    test.it("math.clamp constrains values", () => {
        assert.equal(math.clamp(5, 0, 10), 5);
        assert.equal(math.clamp(-3, 0, 10), 0);
        assert.equal(math.clamp(15, 0, 10), 10);
    });

    test.it("math.abs and rounding", () => {
        assert.equal(math.abs(-7), 7);
        assert.equal(math.abs(7), 7);
        assert.equal(math.floor(3.9), 3);
        assert.equal(math.ceil(3.2), 4);
    });
});

test.describe("strings", () => {
    test.it("case conversion", () => {
        assert.equal(str.upper("hello"), "HELLO");
        assert.equal(str.lower("HELLO"), "hello");
    });

    test.it("trimming", () => {
        assert.equal(str.trim("  hello  "), "hello");
        assert.equal(str.trimStart("  hello  "), "hello  ");
        assert.equal(str.trimEnd("  hello  "), "  hello");
    });

    test.it("searching", () => {
        assert.true(str.contains("hello world", "world"));
        assert.false(str.contains("hello world", "xyz"));
        assert.equal(str.indexOf("hello", "ll"), 2);
        assert.equal(str.indexOf("hello", "xyz"), -1);
    });

    test.it("startsWith and endsWith", () => {
        assert.true(str.startsWith("hello world", "hello"));
        assert.false(str.startsWith("hello world", "world"));
        assert.true(str.endsWith("hello world", "world"));
        assert.false(str.endsWith("hello world", "hello"));
    });

    test.it("replace and replaceAll", () => {
        assert.equal(str.replace("hello world", "world", "Stash"), "hello Stash");
        assert.equal(str.replaceAll("aabbaa", "a", "x"), "xxbbxx");
    });

    test.it("split and join", () => {
        let parts = str.split("a,b,c", ",");
        assert.equal(len(parts), 3);
        assert.equal(parts[0], "a");
        assert.equal(parts[2], "c");
        assert.equal(arr.join(parts, "-"), "a-b-c");
    });

    test.it("slug generation", () => {
        assert.equal(to_slug("Hello World"), "hello-world");
        assert.equal(to_slug("  My Post  "), "my-post");
        assert.equal(to_slug("Stash_Lang"), "stash-lang");
    });

    test.it("string interpolation", () => {
        let name = "Stash";
        let version = 2;
        assert.equal($"Hello, {name}!", "Hello, Stash!");
        assert.equal("Version: ${version}", "Version: 2");
        assert.equal("Sum: ${1 + 2}", "Sum: 3");
    });
});

test.describe("arrays", () => {
    test.it("indexing and length", () => {
        let a = [10, 20, 30];
        assert.equal(len(a), 3);
        assert.equal(a[0], 10);
        assert.equal(a[2], 30);
    });

    test.it("push and pop", () => {
        let a = [1, 2];
        arr.push(a, 3);
        assert.equal(len(a), 3);
        assert.equal(a[2], 3);

        let popped = arr.pop(a);
        assert.equal(popped, 3);
        assert.equal(len(a), 2);
    });

    test.it("map transforms elements", () => {
        let nums = [1, 2, 3, 4];
        let doubled = arr.map(nums, (x) => x * 2);
        assert.equal(doubled[0], 2);
        assert.equal(doubled[3], 8);
    });

    test.it("filter selects elements", () => {
        let nums = [1, 2, 3, 4, 5, 6];
        let evens = arr.filter(nums, (x) => x % 2 == 0);
        assert.equal(len(evens), 3);
        assert.equal(evens[0], 2);
        assert.equal(evens[2], 6);
    });

    test.it("reduce accumulates", () => {
        let nums = [1, 2, 3, 4, 5];
        let sum = arr.reduce(nums, (acc, x) => acc + x, 0);
        assert.equal(sum, 15);
        let product = arr.reduce([1, 2, 3, 4], (acc, x) => acc * x, 1);
        assert.equal(product, 24);
    });

    test.it("sort in-place", () => {
        let nums = [3, 1, 4, 1, 5];
        arr.sort(nums);
        assert.equal(nums[0], 1);
        assert.equal(nums[1], 1);
        assert.equal(nums[2], 3);
        assert.equal(nums[4], 5);
    });

    test.it("find and indexOf", () => {
        let nums = [10, 20, 30, 40];
        let found = arr.find(nums, (x) => x > 25);
        assert.equal(found, 30);
        assert.equal(arr.indexOf(nums, 20), 1);
        assert.equal(arr.indexOf(nums, 99), -1);
        assert.null(arr.find(nums, (x) => x > 100));
    });

    test.it("slice creates sub-array", () => {
        let nums = [1, 2, 3, 4, 5];
        let sub = arr.slice(nums, 1, 4);
        assert.equal(len(sub), 3);
        assert.equal(sub[0], 2);
        assert.equal(sub[2], 4);
    });

    test.it("in operator checks membership", () => {
        let fruits = ["apple", "banana", "cherry"];
        assert.true("banana" in fruits);
        assert.false("mango" in fruits);
    });
});

test.describe("dictionaries", () => {
    test.it("CRUD operations", () => {
        let d = dict.new();
        d["name"] = "Alice";
        d["age"] = 30;

        assert.equal(d["name"], "Alice");
        assert.equal(d["age"], 30);
        assert.equal(dict.size(d), 2);
        assert.true(dict.has(d, "name"));
        assert.false(dict.has(d, "email"));
    });

    test.it("dot access", () => {
        let d = dict.new();
        d["city"] = "Berlin";
        d["country"] = "Germany";
        assert.equal(d.city, "Berlin");
        assert.equal(d.country, "Germany");
    });

    test.it("merge combines dictionaries", () => {
        let defaults = dict.new();
        defaults["color"] = "blue";
        defaults["timeout"] = 30;

        let overrides = dict.new();
        overrides["color"] = "red";

        let merged = dict.merge(defaults, overrides);
        assert.equal(merged["color"], "red");
        assert.equal(merged["timeout"], 30);
    });

    test.it("keys and values", () => {
        let d = dict.new();
        d["x"] = 1;
        d["y"] = 2;
        let keys = dict.keys(d);
        assert.equal(len(keys), 2);
        assert.true("x" in keys);
        assert.true("y" in keys);
        assert.equal(len(dict.values(d)), 2);
    });

    test.it("for-in key-value iteration", () => {
        let d = dict.new();
        d["a"] = 1;
        d["b"] = 2;
        d["c"] = 3;
        let total = 0;
        for (let key, val in d) {
            total += val;
        }
        assert.equal(total, 6);
    });
});

test.describe("types", () => {
    test.it("typeof on all core types", () => {
        assert.equal(typeof(42), "int");
        assert.equal(typeof(3.14), "float");
        assert.equal(typeof("hi"), "string");
        assert.equal(typeof(true), "bool");
        assert.equal(typeof(null), "null");
        assert.equal(typeof([1, 2]), "array");
        assert.equal(typeof(dict.new()), "dict");
        fn f() {}
        assert.equal(typeof(f), "function");
    });

    test.it("no type coercion on equality", () => {
        assert.notEqual(5, "5");
        assert.notEqual(0, false);
        assert.notEqual(0, null);
        assert.notEqual("", false);
        assert.notEqual(1, true);
    });

    test.it("truthiness rules", () => {
        // falsy values
        assert.false(false);
        assert.false(null);
        assert.false(0);
        assert.false(0.0);
        assert.false("");

        // truthy values
        assert.true(1);
        assert.true(-1);
        assert.true("hello");
        assert.true([]);
        assert.true(0.1);
    });
});

test.describe("control flow", () => {
    test.it("switch expression", () => {
        let classify = (n) => n switch {
            0 => "zero",
            1 => "one",
            _ => "many"
        };
        assert.equal(classify(0), "zero");
        assert.equal(classify(1), "one");
        assert.equal(classify(99), "many");
    });

    test.it("range iteration", () => {
        let result = [];
        for (let i in 1..6) {
            arr.push(result, i);
        }
        assert.equal(len(result), 5);
        assert.equal(result[0], 1);
        assert.equal(result[4], 5);
    });

    test.it("range with step", () => {
        let evens = [];
        for (let i in 0..10..2) {
            arr.push(evens, i);
        }
        assert.equal(len(evens), 5);
        assert.equal(evens[0], 0);
        assert.equal(evens[4], 8);
    });

    test.it("array destructuring", () => {
        let [x, y, z] = [10, 20, 30];
        assert.equal(x, 10);
        assert.equal(y, 20);
        assert.equal(z, 30);
    });

    test.it("dict destructuring", () => {
        let d = dict.new();
        d["host"] = "localhost";
        d["port"] = 8080;
        let {host, port} = d;
        assert.equal(host, "localhost");
        assert.equal(port, 8080);
    });

    test.it("ternary operator", () => {
        let max = (a, b) => a > b ? a : b;
        assert.equal(max(3, 7), 7);
        assert.equal(max(9, 4), 9);
    });

    test.it("try and null coalescing", () => {
        let bad = try conv.toInt("not_a_number");
        assert.null(bad);
        assert.equal(bad ?? 42, 42);

        let good = try conv.toInt("123");
        assert.equal(good, 123);
    });

    test.it("assert.throws captures runtime error", () => {
        let msg = assert.throws(() => {
            let a = [1, 2, 3];
            let _ = a[10]; // out-of-bounds
        });
        assert.notNull(msg);
        assert.greater(len(msg), 0);
    });
});

test.describe("closures and lambdas", () => {
    test.it("closure captures enclosing scope", () => {
        fn makeCounter() {
            let count = 0;
            return () => {
                count += 1;
                return count;
            };
        }

        let counter = makeCounter();
        assert.equal(counter(), 1);
        assert.equal(counter(), 2);
        assert.equal(counter(), 3);
    });

    test.it("two closures are independent", () => {
        fn makeAdder(n) {
            return (x) => x + n;
        }
        let add10 = makeAdder(10);
        let add20 = makeAdder(20);
        assert.equal(add10(5), 15);
        assert.equal(add20(5), 25);
    });

    test.it("lambda as argument", () => {
        fn apply(f, x) { return f(x); }
        assert.equal(apply((x) => x * x, 6), 36);
        assert.equal(apply((x) => x + 1, 99), 100);
    });

    test.it("currying via closures", () => {
        fn multiply(a) {
            return (b) => a * b;
        }
        let double = multiply(2);
        let triple = multiply(3);
        assert.equal(double(7), 14);
        assert.equal(triple(7), 21);
    });

    test.it("default parameters", () => {
        fn greet(name, greeting = "Hello") {
            return "${greeting}, ${name}!";
        }
        assert.equal(greet("Alice"), "Hello, Alice!");
        assert.equal(greet("Bob", "Hi"), "Hi, Bob!");
    });

    test.it("multiple default parameters", () => {
        fn connect(host, port = 8080, secure = false) {
            let scheme = secure ? "https" : "http";
            return "${scheme}://${host}:${port}";
        }
        assert.equal(connect("localhost"), "http://localhost:8080");
        assert.equal(connect("example.com", 443, true), "https://example.com:443");
    });
});

test.describe("output capture", () => {
    test.it("captures println output", () => {
        let output = test.captureOutput(() => {
            io.println("Hello, world!");
        });
        assert.equal(output, "Hello, world!\n");
    });

    test.it("captures print without newline", () => {
        let output = test.captureOutput(() => {
            io.print("no newline");
        });
        assert.equal(output, "no newline");
    });

    test.it("captures multiple print calls", () => {
        let output = test.captureOutput(() => {
            io.print("one ");
            io.print("two ");
            io.println("three");
        });
        assert.equal(output, "one two three\n");
    });

    test.it("empty output when nothing printed", () => {
        let output = test.captureOutput(() => {
            let x = 42;
        });
        assert.equal(output, "");
    });

    test.it("inner output does not leak to outer", () => {
        let inner_result = "";
        let outer = test.captureOutput(() => {
            io.print("A");
            inner_result = test.captureOutput(() => {
                io.print("B");
            });
            io.print("C");
        });
        assert.equal(inner_result, "B");
        assert.equal(outer, "AC");
    });
});
