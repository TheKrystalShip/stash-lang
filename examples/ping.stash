#!/usr/bin/env stash

const DEFAULT_ADDRESS: string = "192.168.1.128";
let localAddress: string = "192.168.1.127";

let servers: array = [ DEFAULT_ADDRESS, localAddress ];

fn pingAddress(address: string) {
  let result: CommandResult = $(ping -c 1 {address});

  io.println($"Exit code for ping at address {address}: {result.exitCode}");

  if (result.exitCode != 0) {
    io.println(result.stderr);
  }
}

for (let address: string in servers) {
  pingAddress(address);
}
