#!/usr/bin/env stash

const DEFAULT_ADDRESS = "192.168.1.128";
let localAddress = "192.168.1.127";

let servers = [ DEFAULT_ADDRESS, localAddress ];

fn ping_address(address) {
  let result = $(ping -c 1 {address});

  println($"Exit code for ping at address {address}: {result.exitCode}");

  if (result.exitCode != 0) {
    println(result.stderr);
  }
}

for (let address in servers) {
  ping_address(address);
}
