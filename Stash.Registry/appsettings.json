{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Registry": {
    "Server": {
      "Host": "0.0.0.0",
      "Port": 8080,
      "BasePath": "",
      "Tls": {
        "Enabled": false,
        "Cert": "",
        "Key": ""
      }
    },
    "Database": {
      "Type": "sqlite",
      "Path": "data/registry.db",
      "ConnectionString": ""
    },
    "Storage": {
      "Type": "filesystem",
      "Path": "data/packages",
      "Bucket": "",
      "Region": "",
      "Endpoint": "",
      "AccessKey": "",
      "SecretKey": ""
    },
    "Auth": {
      "Type": "local",
      "RegistrationEnabled": false,
      "ApiTokenExpiry": "90d",
      "AccessTokenExpiry": "1h",
      "RefreshTokenExpiry": "90d",
      "LdapServer": "",
      "LdapPort": 389,
      "LdapBaseDn": "",
      "LdapUserFilter": "",
      "OidcAuthority": "",
      "OidcClientId": "",
      "OidcClientSecret": ""
    },
    "Security": {
      "MaxPackageSize": "10MB",
      "RequiredIntegrity": "sha256",
      "UnpublishWindow": "72h",
      "JwtSigningKey": "",
      "ScopeOwnershipPolicy": "Claim",
      "MaxTokenLifetime": "90.00:00:00"
    },
    "RateLimiting": {
      "Enabled": false,
      "Auth": {
        "MaxAttempts": 10,
        "WindowSeconds": 300,
        "MaxPerHour": 0,
        "MaxPerMinute": 0
      },
      "Publish": {
        "MaxAttempts": 5,
        "WindowSeconds": 60,
        "MaxPerHour": 30,
        "MaxPerMinute": 0
      },
      "Download": {
        "MaxAttempts": 120,
        "WindowSeconds": 60,
        "MaxPerHour": 0,
        "MaxPerMinute": 120
      },
      "Search": {
        "MaxAttempts": 60,
        "WindowSeconds": 60,
        "MaxPerHour": 0,
        "MaxPerMinute": 60
      }
    },
    "Bootstrap": {
      "AdminUsername": "admin",
      "AdminEmail": "",
      "AdminPasswordEnv": ""
    },
    "Cors": {
      "Enabled": false,
      "AllowedOrigins": [],
      "AllowedMethods": [ "GET", "HEAD" ],
      "AllowedHeaders": [ "Content-Type", "Authorization", "If-None-Match", "If-Modified-Since" ],
      "AllowCredentials": false
    },
    "Metrics": {
      "Enabled": true,
      "IpMode": "hashed",
      "IpHashSecret": "",
      "Raw": {
        "RetentionDays": 30
      },
      "Rollup": {
        "IntervalMinutes": 60
      }
    },
    "Audit": {
      "RetentionDays": 0,
      "TamperEvidence": {
        "Enabled": false,
        "HashSecret": ""
      }
    }
  }
}
