{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Registry": {
    "Server": {
      "Host": "0.0.0.0",
      "Port": 8080,
      "BasePath": "/api/v1",
      "Tls": {
        "Enabled": false,
        "Cert": "",
        "Key": ""
      }
    },
    "Database": {
      "Type": "sqlite",
      "Path": "data/registry.db",
      "ConnectionString": ""
    },
    "Storage": {
      "Type": "filesystem",
      "Path": "data/packages",
      "Bucket": "",
      "Region": "",
      "Endpoint": "",
      "AccessKey": "",
      "SecretKey": ""
    },
    "Auth": {
      "Type": "local",
      "RegistrationEnabled": true,
      "ApiTokenExpiry": "90d",
      "AccessTokenExpiry": "1h",
      "RefreshTokenExpiry": "90d",
      "LdapServer": "",
      "LdapPort": 389,
      "LdapBaseDn": "",
      "LdapUserFilter": "",
      "OidcAuthority": "",
      "OidcClientId": "",
      "OidcClientSecret": ""
    },
    "Security": {
      "MaxPackageSize": "10MB",
      "RequiredIntegrity": "sha256",
      "UnpublishWindow": "72h",
      "JwtSigningKey": ""
    },
    "RateLimiting": {
      "Enabled": false,
      "Auth": {
        "MaxAttempts": 10,
        "WindowSeconds": 300,
        "MaxPerHour": 0,
        "MaxPerMinute": 0
      },
      "Publish": {
        "MaxAttempts": 0,
        "WindowSeconds": 0,
        "MaxPerHour": 30,
        "MaxPerMinute": 0
      },
      "Download": {
        "MaxAttempts": 0,
        "WindowSeconds": 0,
        "MaxPerHour": 0,
        "MaxPerMinute": 120
      },
      "Search": {
        "MaxAttempts": 0,
        "WindowSeconds": 0,
        "MaxPerHour": 0,
        "MaxPerMinute": 60
      }
    }
  }
}
