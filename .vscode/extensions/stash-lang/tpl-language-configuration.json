{
  "comments": {
    "blockComment": ["{#", "#}"]
  },
  "brackets": [
    ["{{", "}}"],
    ["{%", "%}"],
    ["{#", "#}"],
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "{{", "close": "}}" },
    { "open": "{%", "close": "%}" },
    { "open": "{#", "close": "#}" },
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    { "open": "{{", "close": "}}" },
    { "open": "{%", "close": "%}" },
    { "open": "{#", "close": "#}" },
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"" }
  ],
  "folding": {
    "markers": {
      "start": "\\{%[-\\s]*(if|for|raw)\\b",
      "end": "\\{%[-\\s]*(endif|endfor|endraw)\\b"
    }
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
