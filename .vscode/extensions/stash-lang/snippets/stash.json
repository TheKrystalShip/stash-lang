{
  "Function Declaration": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params}) {",
      "\t$0",
      "}"
    ],
    "description": "Declare a function"
  },
  "Variable Declaration": {
    "prefix": "let",
    "body": "let ${1:name} = ${2:value};$0",
    "description": "Declare a mutable variable"
  },
  "Constant Declaration": {
    "prefix": "const",
    "body": "const ${1:NAME} = ${2:value};$0",
    "description": "Declare an immutable constant"
  },
  "Struct Declaration": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "\t${2:field1},",
      "\t${3:field2}",
      "}"
    ],
    "description": "Declare a struct"
  },
  "Enum Declaration": {
    "prefix": "enum",
    "body": [
      "enum ${1:Name} {",
      "\t${2:Member1},",
      "\t${3:Member2}",
      "}"
    ],
    "description": "Declare an enum"
  },
  "Interface Declaration": {
    "prefix": "interface",
    "body": [
      "interface ${1:Name} {",
      "\t${2:method}(${3})",
      "}"
    ],
    "description": "Declare an interface"
  },
  "Typed Interface Declaration": {
    "prefix": "interfacet",
    "body": [
      "interface ${1:Name} {",
      "\t${2:field}: ${3:Type},",
      "\t${4:method}(${5:param}: ${6:Type}) -> ${7:ReturnType}",
      "}"
    ],
    "description": "Declare an interface with typed fields and methods"
  },
  "If Statement": {
    "prefix": "if",
    "body": [
      "if (${1:condition}) {",
      "\t$0",
      "}"
    ],
    "description": "If statement"
  },
  "If-Else Statement": {
    "prefix": "ife",
    "body": [
      "if (${1:condition}) {",
      "\t$2",
      "} else {",
      "\t$0",
      "}"
    ],
    "description": "If-else statement"
  },
  "While Loop": {
    "prefix": "while",
    "body": [
      "while (${1:condition}) {",
      "\t$0",
      "}"
    ],
    "description": "While loop"
  },
  "For-In Loop": {
    "prefix": "for",
    "body": [
      "for (let ${1:item} in ${2:collection}) {",
      "\t$0",
      "}"
    ],
    "description": "For-in loop"
  },
  "Command Execution": {
    "prefix": "cmd",
    "body": "let ${1:result} = \\$(${2:command});$0",
    "description": "Execute a shell command"
  },
  "Import Statement": {
    "prefix": "import",
    "body": "import { ${1:name} } from \"${2:module}.stash\";$0",
    "description": "Import from a module"
  },
  "Try Expression": {
    "prefix": "try",
    "body": "try ${1:expression} ?? ${2:fallback}$0",
    "description": "Try expression with fallback"
  },
  "Print Line": {
    "prefix": "pln",
    "body": "println(${1:value});$0",
    "description": "Print value with newline"
  },
  "Interpolated String": {
    "prefix": "str",
    "body": "\\$\"${1:text {${2:expr}}}\"$0",
    "description": "Interpolated string"
  },
  "Shebang": {
    "prefix": "shebang",
    "body": "#!/usr/bin/env stash\n$0",
    "description": "Add shebang line"
  },
  "Typed Function Declaration": {
    "prefix": "fnt",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:Type} {",
      "\t$0",
      "}"
    ],
    "description": "Declare a function with return type"
  },
  "Typed Variable Declaration": {
    "prefix": "lett",
    "body": "let ${1:name}: ${2:Type} = ${3:value};$0",
    "description": "Declare a typed mutable variable"
  },
  "Typed Constant Declaration": {
    "prefix": "constt",
    "body": "const ${1:NAME}: ${2:Type} = ${3:value};$0",
    "description": "Declare a typed immutable constant"
  },
  "Typed Struct Declaration": {
    "prefix": "structt",
    "body": [
      "struct ${1:Name} {",
      "\t${2:field1}: ${3:Type},",
      "\t${4:field2}: ${5:Type}",
      "}"
    ],
    "description": "Declare a struct with typed fields"
  },
  "Switch Expression": {
    "prefix": "switch",
    "body": [
      "${1:value} switch {",
      "  ${2:pattern} => ${3:result},",
      "  _ => ${4:default}",
      "}"
    ],
    "description": "Switch expression with pattern matching"
  },
  "For-In Range Loop": {
    "prefix": "forr",
    "body": [
      "for (let ${1:i} in ${2:0}..${3:10}) {",
      "\t$0",
      "}"
    ],
    "description": "For-in loop over a range"
  },
  "Array Destructuring": {
    "prefix": "letd",
    "body": "let [${1:a}, ${2:b}] = ${3:array};$0",
    "description": "Destructure an array into variables"
  },
  "Dict Destructuring": {
    "prefix": "letdd",
    "body": "let {${1:key1}, ${2:key2}} = ${3:dict};$0",
    "description": "Destructure a dictionary into variables"
  },
  "Multi-line String": {
    "prefix": "ml",
    "body": [
      "\"\"\"",
      "    $0",
      "\"\"\""
    ],
    "description": "Triple-quoted multi-line string"
  },
  "Interpolated Multi-line String": {
    "prefix": "mli",
    "body": [
      "\\$\"\"\"",
      "    $0",
      "\"\"\""
    ],
    "description": "Interpolated triple-quoted multi-line string"
  },
  "Test Case": {
    "prefix": "test.it",
    "body": [
      "test.it(\"${1:test name}\", () => {",
      "\t$0",
      "});"
    ],
    "description": "Define a test case"
  },
  "Describe Block": {
    "prefix": "test.describe",
    "body": [
      "test.describe(\"${1:group name}\", () => {",
      "\t$0",
      "});"
    ],
    "description": "Group tests under a descriptive name"
  },
  "Skip Test": {
    "prefix": "test.skip",
    "body": [
      "test.skip(\"${1:test name}\", () => {",
      "\t$0",
      "});"
    ],
    "description": "Skip a test case"
  },
  "Before All Hook": {
    "prefix": "test.beforeAll",
    "body": [
      "test.beforeAll(() => {",
      "\t$0",
      "});"
    ],
    "description": "Run once before all tests in the test.describe block"
  },
  "After All Hook": {
    "prefix": "test.afterAll",
    "body": [
      "test.afterAll(() => {",
      "\t$0",
      "});"
    ],
    "description": "Run once after all tests in the test.describe block"
  },
  "Before Each Hook": {
    "prefix": "test.beforeEach",
    "body": [
      "test.beforeEach(() => {",
      "\t$0",
      "});"
    ],
    "description": "Run before each test in the test.describe block"
  },
  "After Each Hook": {
    "prefix": "test.afterEach",
    "body": [
      "test.afterEach(() => {",
      "\t$0",
      "});"
    ],
    "description": "Run after each test in the test.describe block"
  },
  "Assert Equal": {
    "prefix": "aeq",
    "body": "assert.equal(${1:actual}, ${2:expected});$0",
    "description": "Assert actual equals expected"
  },
  "Assert True": {
    "prefix": "atrue",
    "body": "assert.true(${1:value});$0",
    "description": "Assert value is truthy"
  }
}
