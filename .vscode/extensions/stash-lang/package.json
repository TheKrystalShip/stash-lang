{
  "name": "stash-lang",
  "displayName": "Stash Language",
  "description": "Full language support for the Stash scripting language — syntax highlighting, LSP-powered diagnostics, autocomplete, formatting, navigation, and more",
  "version": "0.1.0",
  "publisher": "TheKrystalShip",
  "icon": "images/stash-icon.png",
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheKrystalShip/stash-lang"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "activationEvents": [],
  "categories": [
    "Programming Languages",
    "Snippets",
    "Formatters",
    "Linters",
    "Debuggers",
    "Testing"
  ],
  "contributes": {
    "languages": [
      {
        "id": "stash",
        "aliases": [
          "Stash",
          "stash"
        ],
        "extensions": [
          ".stash"
        ],
        "configuration": "./stash-language-configuration.json",
        "firstLine": "^#!.*\\bstash\\b"
      },
      {
        "id": "stash-tpl",
        "aliases": [
          "Stash Template",
          "stash-tpl"
        ],
        "extensions": [
          ".tpl"
        ],
        "configuration": "./tpl-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "stash",
        "scopeName": "source.stash",
        "path": "./syntaxes/stash.tmLanguage.json",
        "semanticHighlighting": true
      },
      {
        "scopeName": "markdown.stash.codeblock",
        "path": "./syntaxes/stash-markdown-injection.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.stash": "stash"
        }
      },
      {
        "language": "stash-tpl",
        "scopeName": "source.stash-tpl",
        "path": "./syntaxes/stash-tpl.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "stash",
        "path": "./snippets/stash.json"
      },
      {
        "language": "stash-tpl",
        "path": "./snippets/stash-tpl.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "stash",
        "scopes": {
          "namespace": [
            "entity.name.namespace.stash"
          ],
          "type": [
            "entity.name.type.stash"
          ],
          "function": [
            "entity.name.function.stash"
          ],
          "parameter": [
            "variable.parameter.stash"
          ],
          "variable": [
            "variable.other.stash"
          ],
          "property": [
            "variable.other.property.stash"
          ],
          "enumMember": [
            "variable.other.enummember.stash"
          ],
          "keyword": [
            "keyword.control.stash"
          ],
          "number": [
            "constant.numeric.stash"
          ],
          "string": [
            "string.quoted.double.stash"
          ],
          "comment": [
            "comment.line.stash"
          ],
          "operator": [
            "keyword.operator.stash"
          ]
        }
      }
    ],
    "configurationDefaults": {
      "[stash-tpl]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true
      },
      "[stash]": {
        "editor.semanticHighlighting.enabled": true,
        "editor.formatOnSave": false,
        "editor.formatOnPaste": false,
        "editor.formatOnType": false,
        "editor.defaultFormatter": "TheKrystalShip.stash-lang",
        "editor.tabSize": 2,
        "editor.insertSpaces": true
      }
    },
    "configuration": {
      "title": "Stash",
      "properties": {
        "stash.lspPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the Stash LSP server binary. If empty, the extension looks for 'stash-lsp' on the system PATH."
        },
        "stash.lsp.debounceTime": {
          "type": "number",
          "default": 25,
          "minimum": 0,
          "maximum": 1000,
          "description": "Debounce delay in milliseconds before running analysis after a document change. Lower values provide faster feedback but use more CPU."
        },
        "stash.lsp.logLevel": {
          "type": "string",
          "default": "warning",
          "enum": [
            "trace",
            "debug",
            "information",
            "warning",
            "error"
          ],
          "enumDescriptions": [
            "Log everything, including very detailed internal events",
            "Log debug-level messages and above",
            "Log informational messages and above",
            "Log warnings and errors only (default)",
            "Log errors only"
          ],
          "description": "Minimum log level for the Stash language server. Logs appear in the Output panel under 'Stash Language Server'."
        },
        "stash.inlayHints.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable inlay hints (parameter name hints at call sites)."
        },
        "stash.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable code lens (reference counts above functions, structs, and enums)."
        },
        "stash.formatting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the Stash document formatter. When disabled, Format Document will have no effect."
        },
        "stash.dapPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the Stash DAP debug adapter binary. If empty, the extension looks for 'stash-dap' on the system PATH."
        },
        "stash.interpreterPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the Stash interpreter binary. If empty, the extension looks for 'stash' on the system PATH."
        },
        "stash.testing.filePattern": {
          "type": "string",
          "default": "**/*.test.stash",
          "description": "Glob pattern for auto-discovering test files."
        },
        "stash.testing.autoDiscover": {
          "type": "boolean",
          "default": true,
          "description": "Automatically discover tests in matching files."
        }
      }
    },
    "breakpoints": [
      {
        "language": "stash"
      }
    ],
    "commands": [
      {
        "command": "stash.showReferences",
        "title": "Show References"
      }
    ],
    "iconThemes": [
      {
        "id": "stash-icons",
        "label": "Stash File Icons",
        "path": "./images/stash-file-icon-theme.json"
      }
    ],
    "debuggers": [
      {
        "type": "stash",
        "label": "Stash Debug",
        "languages": [
          "stash"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to the .stash script to debug.",
                "default": "${file}"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Pause execution at the first statement.",
                "default": false
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the script.",
                "default": "${workspaceFolder}"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Command-line arguments passed to the script.",
                "default": []
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "stash",
            "request": "launch",
            "name": "Debug Stash Script",
            "program": "${file}",
            "stopOnEntry": false,
            "cwd": "${workspaceFolder}"
          }
        ],
        "configurationSnippets": [
          {
            "label": "Stash: Launch Script",
            "description": "Launch and debug a Stash script",
            "body": {
              "type": "stash",
              "request": "launch",
              "name": "Debug ${1:script}",
              "program": "^\"\\${file}\"",
              "stopOnEntry": false,
              "cwd": "^\"\\${workspaceFolder}\""
            }
          }
        ]
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.9.3"
  }
}
