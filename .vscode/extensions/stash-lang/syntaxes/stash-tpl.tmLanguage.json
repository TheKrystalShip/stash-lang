{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Stash Template",
  "scopeName": "source.stash-tpl",
  "patterns": [
    { "include": "#raw-block" },
    { "include": "#template-comment" },
    { "include": "#template-tag" },
    { "include": "#template-expression" }
  ],
  "repository": {

    "raw-block": {
      "name": "meta.raw-block.stash-tpl",
      "begin": "(\\{%-?)\\s*(raw)\\s*(-?%\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.stash-tpl" },
        "2": { "name": "keyword.control.raw.stash-tpl" },
        "3": { "name": "punctuation.definition.tag.end.stash-tpl" }
      },
      "end": "(\\{%-?)\\s*(endraw)\\s*(-?%\\})",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.stash-tpl" },
        "2": { "name": "keyword.control.endraw.stash-tpl" },
        "3": { "name": "punctuation.definition.tag.end.stash-tpl" }
      },
      "contentName": "string.unquoted.raw.stash-tpl"
    },

    "template-comment": {
      "name": "comment.block.template.stash-tpl",
      "begin": "\\{#-?",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.begin.stash-tpl" }
      },
      "end": "-?#\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.comment.end.stash-tpl" }
      }
    },

    "template-tag": {
      "name": "meta.tag.stash-tpl",
      "begin": "(\\{%-?)\\s*",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.stash-tpl" }
      },
      "end": "\\s*(-?%\\})",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.stash-tpl" }
      },
      "patterns": [
        { "include": "#tag-keywords" },
        { "include": "#tag-include-path" },
        { "include": "#template-inner-expression" }
      ]
    },

    "template-expression": {
      "name": "meta.expression.stash-tpl",
      "begin": "(\\{\\{-?)\\s*",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.expression.begin.stash-tpl" }
      },
      "end": "\\s*(-?\\}\\})",
      "endCaptures": {
        "1": { "name": "punctuation.definition.expression.end.stash-tpl" }
      },
      "patterns": [
        { "include": "#filter-pipe" },
        { "include": "#template-inner-expression" }
      ]
    },

    "tag-keywords": {
      "name": "keyword.control.stash-tpl",
      "match": "\\b(if|elif|else|endif|for|endfor|include|raw|endraw|in)\\b"
    },

    "tag-include-path": {
      "name": "string.quoted.double.include.stash-tpl",
      "begin": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.stash-tpl" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.stash-tpl" }
      }
    },

    "filter-pipe": {
      "match": "(\\|)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.operator.filter.stash-tpl" },
        "2": { "name": "support.function.filter.stash-tpl" }
      }
    },

    "template-inner-expression": {
      "patterns": [
        { "include": "#tpl-strings" },
        { "include": "#tpl-numbers" },
        { "include": "#tpl-constants" },
        { "include": "#tpl-operators" },
        { "include": "#tpl-function-call" },
        { "include": "#tpl-identifiers" }
      ]
    },

    "tpl-strings": {
      "name": "string.quoted.double.stash-tpl",
      "begin": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.stash-tpl" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.stash-tpl" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.stash-tpl",
          "match": "\\\\[\\\\\"ntr0]"
        }
      ]
    },

    "tpl-numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.stash-tpl",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.stash-tpl",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "tpl-constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.stash-tpl",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.stash-tpl",
          "match": "\\bnull\\b"
        }
      ]
    },

    "tpl-operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.stash-tpl",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.stash-tpl",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.null-coalescing.stash-tpl",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.optional-chaining.stash-tpl",
          "match": "\\?\\."
        },
        {
          "name": "keyword.operator.ternary.stash-tpl",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.range.stash-tpl",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.arithmetic.stash-tpl",
          "match": "[+\\-*/%]"
        }
      ]
    },

    "tpl-function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.stash-tpl" }
      }
    },

    "tpl-identifiers": {
      "patterns": [
        {
          "name": "punctuation.accessor.dot.stash-tpl",
          "match": "(?<!\\.)\\.(?!\\.)"
        },
        {
          "name": "punctuation.separator.comma.stash-tpl",
          "match": ","
        },
        {
          "name": "variable.other.stash-tpl",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
