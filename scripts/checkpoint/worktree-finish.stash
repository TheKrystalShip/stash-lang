#!/usr/bin/env stash
// worktree-finish.stash <slug>
//
// Integrates a finished feature branch back into main and cleans up its worktree
// (the parallel-features workflow — see .claude/WORKFLOW.md "Running Features in
// Parallel"). Encodes the three merge-time rules:
//   1. merge --no-ff           -> feature lands as one labeled boundary commit
//   2. re-run final_verify     -> green-on-branch does NOT imply green-on-merged-main
//   3. clean up only if green  -> worktree + branch removed only after main verifies
//
// MUST be run from the main checkout (you cannot merge into main from inside the
// feature worktree, where main is not the checked-out branch). The feature must
// already be promoted by /done (its dir lives under .kanban/4-done/ on the branch).
//
// Stash port of worktree-finish.sh. git stays the tool (command expressions);
// Stash owns the merge-time control flow + fail-closed logic. The final_verify
// list is read inline from the promoted plan via _common (re-absorbing the former
// emit-final-verify.stash). Each verify command is interpreted by `bash -c` via a
// strict-passthrough expression (streams live, fails on non-zero).

import { die, load_yaml } from "_common.stash";

// ── Arguments ───────────────────────────────────────────────────────────────
let raw = [];
for (let x in cli.argv) { arr.push(raw, x); }
if (raw.length != 1) {
    die("usage: worktree-finish.stash <slug>", 2);
}
let slug   = raw[0];
let branch = "feature/" + slug;
let main_branch = env.get("MAIN_BRANCH") ?? "main";

// ── Guards ────────────────────────────────────────────────────────────────────
let current = str.trim($(git branch --show-current).stdout);
if (current != main_branch) {
    io.eprintln("error: run from the " + main_branch + " checkout (currently on '" + current + "')");
    io.eprintln("       the feature worktree cannot merge into " + main_branch + " — main is checked out elsewhere");
    env.exit(1);
}
if (str.trim($(git status --porcelain).stdout) != "") {
    die("working tree is dirty; commit or stash before integrating", 1);
}
let branch_ref = "refs/heads/" + branch;
if ($(git show-ref --verify --quiet ${branch_ref}).exitCode != 0) {
    die("branch '" + branch + "' does not exist", 1);
}
// Feature must be promoted on its branch (/done moved it to 4-done).
let promoted_ref = branch + ":.kanban/4-done/" + slug + "/checkpoint.yaml";
if ($(git cat-file -e ${promoted_ref}).exitCode != 0) {
    io.eprintln("error: feature '" + slug + "' is not promoted on '" + branch + "'");
    io.eprintln("       run /done on the feature branch first (it must reach .kanban/4-done/" + slug + "/)");
    env.exit(1);
}

// Locate the worktree bound to this branch (robust against custom paths).
let worktree_path = "";
let prev = "";
for (let line in str.lines($(git worktree list --porcelain).stdout)) {
    if (str.startsWith(line, "worktree ")) {
        prev = str.substring(line, 9);
    } else if (line == ("branch " + branch_ref)) {
        worktree_path = prev;
    }
}

// ── Merge ─────────────────────────────────────────────────────────────────────
io.println("+ git merge --no-ff " + branch);
let merge_msg = "merge: " + branch;
let merge = try $!>(git merge --no-ff ${branch} -m ${merge_msg});
if (merge is Error) {
    io.eprintln("error: merge conflict integrating '" + branch + "' into " + main_branch);
    io.eprintln("       resolve the conflicts (last-to-merge pays the cost), commit, then");
    io.eprintln("       re-run this script — it will skip the merge and continue with verify.");
    env.exit(1);
}

// ── Re-run final_verify against the MERGED main ──────────────────────────────
// Read the now-promoted plan from its 4-done location (the merge brought it in).
let plan = load_yaml(".kanban/4-done/" + slug + "/plan.yaml");   // dies (exit 1) if absent
let cmds = [];
for (let c in dict.get(plan, "final_verify") ?? []) {
    if (conv.toStr(c) != "") { arr.push(cmds, conv.toStr(c)); }
}

// Fail closed: an empty list must NOT be read as "verified" — re-verifying merged
// main is unskippable.
if (cmds.length == 0) {
    io.eprintln("error: no final_verify commands ran — refusing to tear down unverified");
    io.eprintln("       check that .kanban/4-done/" + slug + "/plan.yaml has a 'final_verify:' list.");
    io.eprintln("       The merge is preserved; worktree and branch left in place.");
    env.exit(1);
}

for (let cmd in cmds) {
    io.println("+ " + cmd);
    let v = try $!>(bash -c ${cmd});
    if (v is Error) {
        io.eprintln("error: final_verify FAILED on merged " + main_branch + " — likely a semantic conflict");
        io.eprintln("       between this feature and work already on " + main_branch + ".");
        io.eprintln("       The merge is preserved. Fix forward on " + main_branch + "; do NOT abort.");
        io.eprintln("       Worktree and branch left in place: " + worktree_path + "  (" + branch + ")");
        env.exit(1);
    }
}

// ── Green on merged main — safe to clean up ──────────────────────────────────
// Wrap the teardown so a git failure exits with git's code (like bash set -e),
// not a Stash stack trace.
if (worktree_path != "" && fs.dirExists(worktree_path)) {
    io.println("+ git worktree remove " + worktree_path);
    let rm = try $!>(git worktree remove ${worktree_path});
    if (rm is Error) { env.exit(rm.exitCode); }
}
io.println("+ git branch -d " + branch);
let bd = try $!>(git branch -d ${branch});
if (bd is Error) { env.exit(bd.exitCode); }

io.println("integrated: " + branch + " -> " + main_branch + " (final_verify green); worktree and branch removed");
env.exit(0);
